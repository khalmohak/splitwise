DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# Firebase Auth
FIREBASE_PROJECT_ID=your-firebase-project-id
# Base64 of the service account JSON. Preferred in deployed environments
# (Secrets Manager / SSM). Leave blank locally to read the JSON from disk.
FIREBASE_SERVICE_ACCOUNT_B64=
# Optional override path for local dev. Defaults to
# ./firebase-service-account-key.json relative to CWD.
FIREBASE_SERVICE_ACCOUNT_PATH=

# Optional for local dev only (S3 client). Lambda sets AWS_REGION automatically.
# AWS_REGION=ap-south-1

# S3 bucket for receipts/avatars. The serverless.yml resources block creates
# `${service}-${stage}-uploads`; in local dev set whichever bucket your
# AWS credentials can write to.
S3_BUCKET=talo-backend-dev-uploads

# Optional. When unset, /expenses/suggest and /files/parse-receipt return
# empty/default outputs rather than erroring.
OPENAI_API_KEY=

# Frontend base URL used to construct invite links.
APP_BASE_URL=http://localhost:5173

# Transactional email. Leave RESEND_API_KEY blank in non-prod if you want
# sends to be skipped.
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@talk.talo.club
