{
  "name": "talo-backend-serverless",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node scripts/run-serverless.mjs dev offline start",
    "offline:dev": "node scripts/run-serverless.mjs dev offline start",
    "offline:prod": "node scripts/run-serverless.mjs prod offline start",
    "deploy": "node scripts/run-serverless.mjs dev deploy",
    "deploy:dev": "node scripts/run-serverless.mjs dev deploy",
    "deploy:prod": "node scripts/run-serverless.mjs prod deploy",
    "remove": "node scripts/run-serverless.mjs dev remove",
    "remove:dev": "node scripts/run-serverless.mjs dev remove",
    "remove:prod": "node scripts/run-serverless.mjs prod remove",
    "logs": "node scripts/run-serverless.mjs dev logs -f api -t",
    "logs:dev": "node scripts/run-serverless.mjs dev logs -f api -t",
    "logs:prod": "node scripts/run-serverless.mjs prod logs -f api -t",
    "typecheck": "tsc --noEmit",
    "package": "node scripts/run-serverless.mjs dev package",
    "package:dev": "node scripts/run-serverless.mjs dev package",
    "package:prod": "node scripts/run-serverless.mjs prod package",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "node scripts/run-with-env.mjs dev drizzle-kit migrate",
    "db:migrate:dev": "node scripts/run-with-env.mjs dev drizzle-kit migrate",
    "db:migrate:prod": "node scripts/run-with-env.mjs prod drizzle-kit migrate",
    "db:push": "node scripts/run-with-env.mjs dev drizzle-kit push",
    "db:push:dev": "node scripts/run-with-env.mjs dev drizzle-kit push",
    "db:push:prod": "node scripts/run-with-env.mjs prod drizzle-kit push",
    "db:studio": "node scripts/run-with-env.mjs dev drizzle-kit studio",
    "db:studio:dev": "node scripts/run-with-env.mjs dev drizzle-kit studio",
    "db:studio:prod": "node scripts/run-with-env.mjs prod drizzle-kit studio",
    "db:seed": "node scripts/run-with-env.mjs dev tsx src/scripts/seed.ts",
    "db:seed:dev": "node scripts/run-with-env.mjs dev tsx src/scripts/seed.ts",
    "db:seed:prod": "node scripts/run-with-env.mjs prod tsx src/scripts/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/client-sns": "^3.1048.0",
    "@aws-sdk/client-sqs": "^3.1047.0",
    "@aws-sdk/s3-request-presigner": "^3.700.0",
    "@hono/node-server": "^1.13.7",
    "@neondatabase/serverless": "^0.10.4",
    "drizzle-orm": "^0.36.4",
    "firebase-admin": "^13.0.1",
    "hono": "^4.6.14",
    "jose": "^5.9.6",
    "pg": "^8.13.1",
    "resend": "^6.12.3",
    "ws": "^8.18.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.146",
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.10",
    "@types/ws": "^8.5.13",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.30.0",
    "esbuild": "^0.24.0",
    "serverless": "^3.40.0",
    "serverless-dotenv-plugin": "^6.0.0",
    "serverless-esbuild": "^1.55.1",
    "serverless-offline": "^13.9.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20"
  }
}
